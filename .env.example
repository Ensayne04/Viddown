# .env.example

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key  # Your Firebase API Key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com  # Your Firebase Auth Domain
FIREBASE_DATABASE_URL=https://your_project_id.firebaseio.com  # Your Firebase Database URL
FIREBASE_PROJECT_ID=your_project_id  # Your Firebase Project ID
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com  # Your Firebase Storage Bucket
FIREBASE_MESSAGING_SENDER_ID=your_sender_id  # Your Firebase Messaging Sender ID
FIREBASE_APP_ID=your_app_id  # Your Firebase App ID
FIREBASE_MEASUREMENT_ID=your_measurement_id  # Your Firebase Measurement ID

# Stripe Configuration
STRIPE_API_KEY=your_stripe_api_key  # Your Stripe API Key
STRIPE_WEBHOOK_SECRET=your_webhook_secret  # Your Stripe Webhook Secret

# Google AI Configuration
GOOGLE_AI_API_KEY=your_google_ai_api_key  # Your Google AI API Key
GOOGLE_AI_PROJECT_ID=your_google_ai_project_id  # Your Google AI Project ID

# Example Usage
# After copying this file to .env, replace the values with your own credentials and keep it secure.

# Note:
# 1. Never commit your actual .env file to your version control.
# 2. Use this template to manage your environment variables securely.