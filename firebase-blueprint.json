{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{uid}": {
      "schema": "User",
      "description": "User profile collection"
    }
  }
}
